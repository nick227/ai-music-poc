APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

DATA_DIR=./data
DEFAULT_GENERATOR=auto-render
MAX_DURATION_SECONDS=240
MAX_PROMPT_CHARS=2000
MAX_LYRICS_CHARS=10000

ENABLE_CORS=true
CORS_ORIGINS=http://localhost:8000,http://localhost:5173

# ACE-Step command adapter. The app spawns ACE per job — no Gradio/API daemon required.
# Day-to-day: ACE_ENABLED=true with paths below; start the app only (python run.py).
ACE_ENABLED=true
# ACE paths — bootstrap exports these at runtime; align .env for `python run.py` without bootstrap.
ACE_STEP_DIR=${HOME}/models/ACE-Step-1.5
ACE_PYTHON=${HOME}/models/ACE-Step-1.5/.venv/bin/python
ACE_SCRIPT=./scripts/ace_runner.py
ACE_MODEL_DIR=${HOME}/models/ACE-Step-1.5/checkpoints
ACE_OUTPUT_DIR=./data/model_outputs
ACE_TIMEOUT_SECONDS=3600
ACE_DEVICE=cuda
ACE_ALLOW_FALLBACK=true
SAVE_FULL_LYRICS=false

# Shared Hugging Face cache (optional). Defaults to ~/.cache/huggingface if unset.
# HF_CACHE_DIR=${HOME}/.cache/huggingface

# Template variables include:
# $python $script $prompt_file $lyrics_file $negative_file $request_file $output_path
# $duration_seconds $seed $bpm $key $mode $structure $quality $guidance_scale $model_dir $device
# $use_lora $lora_path $lora_scale
# Prefer file args for prompt/lyrics to avoid shell quoting and long-command problems.
ACE_COMMAND_TEMPLATE=$python $script --prompt-file $prompt_file --lyrics-file $lyrics_file --negative-prompt-file $negative_file --request-file $request_file --output $output_path --model-dir $model_dir --duration $duration_seconds --seed $seed --guidance-scale $guidance_scale --quality $quality --device $device --use-lora $use_lora --lora-path $lora_path --lora-scale $lora_scale

# Studio training stays behind a separate adapter boundary. The dry-run adapter
# renders this command and records it under data/training_runs; it does not launch
# real ACE training.
TRAINING_ENABLED=true
TRAINING_ADAPTER=mock-training
TRAINING_MOCK_STEP_DELAY_SECONDS=0.05
ACE_TRAIN_PYTHON=${HOME}/models/ACE-Step-1.5/.venv/bin/python
ACE_TRAIN_SCRIPT=./scripts/ace_train_runner.py
ACE_TRAIN_TIMEOUT_SECONDS=7200
# Template variables include:
# $python $script $request_file $package_path $run_dir $config_file $log_file
# $output_dir $artifacts_dir $model_dir $device $preset $steps $rank $learning_rate $epochs
ACE_TRAIN_COMMAND_TEMPLATE=$python $script --request-file $request_file --package $package_path --config $config_file --output-dir $output_dir --model-dir $model_dir --device $device --steps $steps --rank $rank --learning-rate $learning_rate --epochs $epochs
# Real ACE turbo LoRA training (subprocess via scripts/ace_train_runner.py).
# TRAINING_ADAPTER=ace-step-real
# ACE_REAL_TRAINING_ENABLED=true
# ACE_TRAIN_DRY_RUN=false
# Each run must also pass confirm_real_training=true in the API request.
ACE_REAL_TRAINING_ENABLED=false
ACE_TRAIN_DRY_RUN=true
ACE_TRAIN_CHECKPOINT_DIR=${HOME}/models/ACE-Step-1.5/checkpoints
# Claude API — enables AI prompt analysis at /api/analyze-prompt
ANTHROPIC_API_KEY=
