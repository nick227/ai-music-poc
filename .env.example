APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

DATA_DIR=./data
DEFAULT_GENERATOR=auto-render
MAX_DURATION_SECONDS=240
MAX_PROMPT_CHARS=2000
MAX_LYRICS_CHARS=10000

ENABLE_CORS=true
CORS_ORIGINS=http://localhost:8000,http://localhost:5173

# ACE-Step command adapter. The app works without ACE installed.
# V3.2 expects ACE to live in its own external environment and be called by command.
ACE_ENABLED=false
ACE_STEP_DIR=/home/administrator/models/ACE-Step-1.5
ACE_PYTHON=/home/administrator/models/ACE-Step-1.5/.venv/bin/python
ACE_SCRIPT=./scripts/ace_runner.py
ACE_MODEL_DIR=/mnt/c/Users/Administrator/.cache/huggingface/ace-step-checkpoints
ACE_OUTPUT_DIR=./data/model_outputs
ACE_TIMEOUT_SECONDS=3600
ACE_DEVICE=cuda
ACE_ALLOW_FALLBACK=true
SAVE_FULL_LYRICS=false

# Shared Hugging Face cache for ACE/Transformers/Diffusers downloads.
# Use an existing cache to avoid duplicate model downloads. Ollama's .ollama/models
# folder is not compatible with ACE-Step checkpoints.
HF_CACHE_DIR=/mnt/c/Users/Administrator/.cache/huggingface

# Template variables include:
# $python $script $prompt_file $lyrics_file $negative_file $request_file $output_path
# $duration_seconds $seed $bpm $key $mode $structure $quality $guidance_scale $model_dir $device
# Prefer file args for prompt/lyrics to avoid shell quoting and long-command problems.
ACE_COMMAND_TEMPLATE=$python $script --prompt-file $prompt_file --lyrics-file $lyrics_file --negative-prompt-file $negative_file --request-file $request_file --output $output_path --model-dir $model_dir --duration $duration_seconds --seed $seed --guidance-scale $guidance_scale --quality $quality --device $device
# Claude API — enables AI prompt analysis at /api/analyze-prompt
ANTHROPIC_API_KEY=
